# LLM provider (OpenAI-compatible chat-completions endpoint).
#
# SaaS-Bench's reference agent uses browser-use, which talks to any
# OpenAI-compatible API.
# (https://developer.qiniu.com/aitokenapi/13379/real-time-ai-interface-api).
# You can point these at any OpenAI-compatible provider.
LLM_API_KEY=sk-replace-me
LLM_BASE_URL=base-url
LLM_MODEL=your-model-name

# Optional: where per-task transient files live (chrome user-data dirs and
# agent file-system workdirs). Defaults to $TMPDIR/saas_bench. Override if
# /tmp is small or on a slow filesystem.
# SAAS_BENCH_TMP=/tmp/saas_bench
